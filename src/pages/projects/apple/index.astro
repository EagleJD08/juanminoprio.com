---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@components/Navbar.astro";
import Footer from "@components/Footer.astro";
import HookSection from "@components/apple/HookSection";
import RevenueBreakdown from "@components/apple/RevenueBreakdown";
import IPhoneChapter from "@components/apple/IPhoneChapter";
import MacIPadChapter from "@components/apple/MacIPadChapter";
import WearablesChapter from "@components/apple/WearablesChapter";
import ServicesChapter from "@components/apple/ServicesChapter";
import ProfitStory from "@components/apple/ProfitStory";
import InfrastructureChapter from "@components/apple/InfrastructureChapter";
import Takeaway from "@components/apple/Takeaway";
import ProgressIndicator from "@components/shared/ProgressIndicator";
import HowIBuiltThis from "@components/shared/HowIBuiltThis";
---

<BaseLayout
  title="How Apple Makes Money — Juan Minoprio"
  description="An interactive data story breaking down Apple's $416.2B revenue model across 5 streams — iPhone, Services, Mac, iPad, and Wearables. FY2025 data across 9 chapters."
  ogImage="/images/portfolio/apple-revenue-thumb.svg"
>
  <Navbar />
  <ProgressIndicator client:load totalChapters={9} />

  <main id="main">
    <HookSection client:load />
    <RevenueBreakdown client:visible />
    <IPhoneChapter client:visible />
    <MacIPadChapter client:visible />
    <WearablesChapter client:visible />
    <ServicesChapter client:visible />
    <ProfitStory client:visible />
    <InfrastructureChapter client:visible />
    <Takeaway client:visible />
    <HowIBuiltThis
      client:visible
      theme="dark"
      timeToBuild="~12 hours over 3 days"
      aiTools={["Claude (analysis + copy)", "Cursor (code)", "ChatGPT (data structuring)"]}
      dataSources={[
        "Apple FY2025 10-K Annual Report",
        "Q1 FY2026 Earnings Release (Jan 2026)",
        "Apple Newsroom segment press releases",
        "Macrotrends historical revenue data",
      ]}
      analyticalApproach="Started with the 10-K income statement, then decomposed each segment across 4 fiscal years to find the trend story. Calculated YoY growth rates, gross margins per segment, and revenue mix shifts. The key insight — Services' margin expansion — emerged only after normalizing by revenue contribution."
      designDecisions="Chose a chapter-by-chapter scroll narrative instead of a dashboard so each insight lands before the next. Used Apple's own dark #1D1D1F background to echo the product aesthetic. Recharts with custom tooltips rather than D3 to keep the bundle lightweight. Progress indicator gives users a sense of journey length upfront."
      lessonsLearned="The hardest part wasn't the charts — it was writing tight narrative commentary for each. The flywheel concept only clicked late in the process, which means the early chapters could be richer with that framing in mind. Next time: outline the narrative arc before touching code."
    />
  </main>

  <Footer />
</BaseLayout>
