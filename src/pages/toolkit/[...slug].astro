---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import AdvisoryBoardDiagram from '@components/toolkit/AdvisoryBoardDiagram';
import HookLabDiagram from '@components/toolkit/HookLabDiagram';
import ScrollReveal from '@components/ScrollReveal.astro';

export async function getStaticPaths() {
  const entries = await getCollection('toolkit');
  // Only generate pages for "built" type products
  return entries
    .filter(entry => entry.data.type === 'built')
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;

const gradientStyle = entry.data.gradient.via
  ? `linear-gradient(135deg, ${entry.data.gradient.from}, ${entry.data.gradient.via}, ${entry.data.gradient.to})`
  : `linear-gradient(135deg, ${entry.data.gradient.from}, ${entry.data.gradient.to})`;

const categoryColors: Record<string, string> = {
  'content': 'bg-terracotta/10 text-terracotta',
  'decision-making': 'bg-dusty-blue/10 text-dusty-blue',
  'productivity': 'bg-soft-plum/10 text-soft-plum',
};

// Map slug to diagram component
const diagramComponents: Record<string, string> = {
  'hook-lab': 'HookLabDiagram',
  'advisory-board': 'AdvisoryBoardDiagram',
};
const diagramType = diagramComponents[entry.id] || null;
---

<BaseLayout
  title={`${entry.data.title} — Toolkit — Juan Minoprio`}
  description={entry.data.description}
>
  <Navbar />

  <main id="main" class="pt-28 pb-24 md:pb-32">
    <div class="mx-auto max-w-6xl px-6">

      <!-- Back link -->
      <a
        href="/toolkit"
        class="inline-flex items-center gap-2 text-sm font-body text-terracotta hover:text-terracotta/80 transition-colors duration-200 mb-6"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        <span data-lang-en>Back to Toolkit</span>
        <span data-lang-es>Volver al Toolkit</span>
      </a>

      <!-- Hero Banner -->
      <div
        class="reveal rounded-[20px] overflow-hidden p-10 md:p-12 relative"
        style={`background: ${gradientStyle}`}
      >
        <div class="absolute inset-0 opacity-[0.06]" style="background: radial-gradient(circle at 20% 40%, white 1px, transparent 1px), radial-gradient(circle at 80% 60%, white 1px, transparent 1px), radial-gradient(circle at 50% 20%, white 1px, transparent 1px); background-size: 80px 80px;"></div>
        <div class="relative z-10">
          <div class="flex gap-2 mb-4">
            <span class="text-[10px] font-medium bg-white/15 text-white px-3 py-1 rounded-full backdrop-blur-sm">
              <span data-lang-en>Open Source</span>
              <span data-lang-es>Código Abierto</span>
            </span>
            <span class="text-[10px] font-medium bg-white/15 text-white px-3 py-1 rounded-full backdrop-blur-sm">
              {entry.data.category}
            </span>
          </div>
          <div class="text-5xl mb-3">{entry.data.icon}</div>
          <h1 class="text-3xl md:text-4xl font-heading font-bold text-white mb-2">{entry.data.title}</h1>
          <p class="text-sm md:text-base text-white/80 max-w-lg">
            <span data-lang-en>{entry.data.tagline}</span>
            <span data-lang-es>{entry.data.tagline_es || entry.data.tagline}</span>
          </p>
          <div class="flex gap-3 mt-8">
            <a
              href={entry.data.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-heading font-semibold bg-white text-navy px-6 py-3 rounded-xl hover:bg-white/90 transition-colors duration-200"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              <span data-lang-en>Clone from GitHub</span>
              <span data-lang-es>Clonar desde GitHub</span>
            </a>
            {entry.data.videoUrl ? (
              <a
                href={entry.data.videoUrl}
                class="inline-flex items-center gap-2 text-sm font-heading font-medium text-white px-6 py-3 rounded-xl border border-white/20 hover:bg-white/10 transition-colors duration-200"
              >
                <span data-lang-en>Watch Demo ▶</span>
                <span data-lang-es>Ver Demo ▶</span>
              </a>
            ) : (
              <span
                class="inline-flex items-center gap-2 text-sm font-heading font-medium text-white/40 px-6 py-3 rounded-xl border border-white/10 cursor-not-allowed"
                title="Coming soon"
              >
                <span data-lang-en>Watch Demo ▶</span>
                <span data-lang-es>Ver Demo ▶</span>
              </span>
            )}
          </div>
        </div>
      </div>

      <!-- The Problem -->
      <section class="mt-16 md:mt-20 reveal">
        <span class="font-body text-xs uppercase tracking-widest text-terracotta">
          <span data-lang-en>The Problem</span>
          <span data-lang-es>El Problema</span>
        </span>
        <h2 class="mt-3 font-heading font-bold text-2xl md:text-3xl text-navy">
          <span data-lang-en>{entry.data.problemHeading}</span>
          <span data-lang-es>{entry.data.problemHeading_es || entry.data.problemHeading}</span>
        </h2>
        <div class="mt-6 text-slate leading-relaxed max-w-2xl whitespace-pre-line">
          <span data-lang-en>{entry.data.problem}</span>
          <span data-lang-es>{entry.data.problem_es || entry.data.problem}</span>
        </div>
      </section>

      <!-- How It Works -->
      <section class="mt-16 md:mt-20 reveal">
        <span class="font-body text-xs uppercase tracking-widest text-terracotta">
          <span data-lang-en>How It Works</span>
          <span data-lang-es>Cómo Funciona</span>
        </span>
        <h2 class="mt-3 mb-8 font-heading font-bold text-2xl md:text-3xl text-navy">
          {entry.id === 'advisory-board' && (
            <>
              <span data-lang-en>Six perspectives, one decision</span>
              <span data-lang-es>Seis perspectivas, una decisión</span>
            </>
          )}
          {entry.id === 'hook-lab' && (
            <>
              <span data-lang-en>From one hook to your top 10</span>
              <span data-lang-es>De un hook a tu top 10</span>
            </>
          )}
        </h2>
        {entry.id === 'advisory-board' && <AdvisoryBoardDiagram client:visible />}
        {entry.id === 'hook-lab' && <HookLabDiagram client:visible />}
      </section>

      <!-- In Action (Screenshot / Demo) -->
      <section class="mt-16 md:mt-20 reveal">
        <span class="font-body text-xs uppercase tracking-widest text-terracotta">
          <span data-lang-en>In Action</span>
          <span data-lang-es>En Acción</span>
        </span>
        <h2 class="mt-3 mb-8 font-heading font-bold text-2xl md:text-3xl text-navy">
          <span data-lang-en>See it work</span>
          <span data-lang-es>Míralo en acción</span>
        </h2>
        <div class="bg-navy rounded-2xl p-1">
          <div class="bg-navy rounded-xl min-h-[300px] flex items-center justify-center">
            {entry.data.screenshot ? (
              <img
                src={entry.data.screenshot}
                alt={`${entry.data.title} screenshot`}
                class="rounded-xl w-full h-auto"
              />
            ) : (
              <div class="text-center py-16">
                <div class="text-4xl mb-3">📸</div>
                <p class="text-sm text-slate">
                  <span data-lang-en>Screenshot coming soon</span>
                  <span data-lang-es>Captura de pantalla próximamente</span>
                </p>
              </div>
            )}
          </div>
        </div>
      </section>

      <!-- GitHub CTA Banner -->
      <section class="mt-16 md:mt-20 reveal">
        <div class="bg-gradient-to-br from-navy to-navy/90 rounded-2xl p-10 md:p-12 text-center">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-3">
            {entry.id === 'advisory-board' && (
              <>
                <span data-lang-en>Ready to build your own board?</span>
                <span data-lang-es>¿Listo para construir tu propio directorio?</span>
              </>
            )}
            {entry.id === 'hook-lab' && (
              <>
                <span data-lang-en>Ready to test your hooks?</span>
                <span data-lang-es>¿Listo para probar tus hooks?</span>
              </>
            )}
          </h2>
          <p class="text-sm text-white/60 mb-8">
            <span data-lang-en>Free, open source, and ready to clone.</span>
            <span data-lang-es>Gratis, código abierto y listo para clonar.</span>
          </p>
          <a
            href={entry.data.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-heading font-semibold bg-white text-navy px-8 py-3.5 rounded-xl hover:bg-white/90 transition-colors duration-200"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            <span data-lang-en>Clone from GitHub</span>
            <span data-lang-es>Clonar desde GitHub</span>
          </a>
        </div>
      </section>

      <!-- Back to Toolkit footer -->
      <div class="mt-12 text-center">
        <a href="/toolkit" class="text-sm text-terracotta hover:text-terracotta/80 transition-colors duration-200">
          <span data-lang-en>← Back to Toolkit</span>
          <span data-lang-es>← Volver al Toolkit</span>
        </a>
      </div>

    </div>
  </main>

  <Footer />
  <ScrollReveal />
</BaseLayout>
