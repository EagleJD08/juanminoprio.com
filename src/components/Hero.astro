---
import HeroCollage from './HeroCollage.tsx';
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-snow">
  <!-- Animated background shapes -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-cocoa/[0.06] animate-float"></div>
    <div class="absolute top-1/3 -left-32 w-72 h-72 rounded-full bg-navy/[0.06] animate-float" style="animation-delay: -2s;"></div>
    <div class="absolute -bottom-16 right-1/4 w-64 h-64 rounded-full bg-navy/[0.06] animate-float" style="animation-delay: -4s;"></div>
    <!-- Subtle dot grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #1A1A1A 1px, transparent 1px); background-size: 48px 48px;"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6 py-20 md:py-0 w-full">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">
      <!-- Text content -->
      <div class="flex-1 text-center md:text-left">
        <p class="animate-fade-in font-body text-sm font-medium tracking-widest uppercase text-cocoa mb-6">
          Marketing &middot; Finance &middot; AI
        </p>

        <h1 class="font-heading font-bold text-5xl md:text-6xl lg:text-7xl leading-[1.1] text-ink">
          <span class="hero-word">Making</span>{" "}
          <span class="hero-word">the</span><br />
          <span class="hero-word">complex</span>{" "}
          <span class="hero-word relative inline-block">
            <span class="relative z-10">clear.</span>
            <span class="absolute bottom-2 left-0 w-full h-3 bg-cocoa/20 rounded-sm"></span>
          </span>
        </h1>

        <p class="animate-fade-up font-accent italic text-xl md:text-2xl text-charcoal/80 mt-6 max-w-lg" style="animation-delay: 0.2s;">
          The person who understands how money, products, and attention work — and makes it clear for everyone else.
        </p>

        <div class="animate-fade-up flex flex-col sm:flex-row items-center gap-4 mt-10 md:justify-start justify-center" style="animation-delay: 0.4s;">
          <a
            href="https://www.linkedin.com/in/juanminoprio/"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 bg-navy text-white font-body font-medium px-7 py-3.5 rounded-full cursor-pointer hover:bg-navy/90 hover:shadow-lg hover:shadow-navy/20 transition-all duration-300 ease-out"
          >
            <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            Follow on LinkedIn
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a
            href="#resume"
            class="group inline-flex items-center gap-2 text-ink font-body font-medium px-7 py-3.5 rounded-full border border-ink/15 cursor-pointer hover:border-ink/40 hover:bg-ink/[0.03] transition-all duration-300"
          >
            View my experience
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          </a>
        </div>
      </div>

      <!-- JDM Particle Constellation -->
      <div class="w-full md:flex-1 md:min-w-0 max-w-xl">
        <HeroCollage client:load />
      </div>
    </div>

  </div>
</section>
