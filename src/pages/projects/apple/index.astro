---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@components/Navbar.astro";
import Footer from "@components/Footer.astro";
import HookSection from "@components/apple/HookSection";
import RevenueBreakdown from "@components/apple/RevenueBreakdown";
import IPhoneChapter from "@components/apple/IPhoneChapter";
import MacIPadChapter from "@components/apple/MacIPadChapter";
import WearablesChapter from "@components/apple/WearablesChapter";
import ServicesChapter from "@components/apple/ServicesChapter";
import ProfitStory from "@components/apple/ProfitStory";
import InfrastructureChapter from "@components/apple/InfrastructureChapter";
import Takeaway from "@components/apple/Takeaway";
import ProgressIndicator from "@components/shared/ProgressIndicator";
---

<BaseLayout
  title="How Apple Makes Money — Juan Minoprio"
  description="An interactive data story breaking down Apple's $416.2B revenue model across 5 streams — iPhone, Services, Mac, iPad, and Wearables. FY2025 data across 9 chapters."
  ogImage="/images/portfolio/apple-revenue-thumb.svg"
>
  <Navbar />
  <ProgressIndicator client:load totalChapters={9} />

  <main id="main">
    <HookSection client:load />
    <RevenueBreakdown client:visible />
    <IPhoneChapter client:visible />
    <MacIPadChapter client:visible />
    <WearablesChapter client:visible />
    <ServicesChapter client:visible />
    <ProfitStory client:visible />
    <InfrastructureChapter client:visible />
    <Takeaway client:visible />
  </main>

  <Footer />
</BaseLayout>
