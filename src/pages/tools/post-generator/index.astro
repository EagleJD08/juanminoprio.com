---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@components/Navbar.astro";
import Footer from "@components/Footer.astro";
import PostGenerator from "@components/post-generator/PostGenerator";
---

<BaseLayout
  title="LinkedIn Post Generator — Juan Minoprio"
  description="Turn any idea into a LinkedIn post and learn why it works. Free tool powered by proven content frameworks."
>
  <Navbar />

  <main id="main" class="pt-24 pb-16">
    <PostGenerator client:load />
  </main>

  <Footer />
</BaseLayout>
