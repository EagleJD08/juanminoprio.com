---
import DisplayCards from './DisplayCards';
---

<section id="about" class="py-24 md:py-32 bg-white relative overflow-hidden">
  <!-- Decorative accent -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-sand to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal max-w-2xl">
      <span class="font-body text-xs font-medium tracking-widest uppercase text-terracotta">About</span>
      <h2 class="mt-3 font-heading font-bold text-3xl md:text-5xl text-navy leading-tight">
        Insider perspective,<br />
        <span class="text-slate/50">outsider thinking.</span>
      </h2>
    </div>

    <div class="mt-12 grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- Bio text -->
      <div class="reveal space-y-5" style="transition-delay: 100ms;">
        <p class="text-lg text-slate leading-relaxed">
          I'm a marketing professional at one of the largest financial institutions in the U.S., where I've seen firsthand how money, products, and attention intersect.
        </p>
        <p class="text-lg text-slate leading-relaxed">
          I think like a builder, communicate like a storyteller, and work like an analyst. My goal is simple: take complex ideas and make them clear for everyone.
        </p>
        <p class="font-accent italic text-lg text-navy/70">
          "Cross-functional fluency is the rarest skill in business — most people only speak one language."
        </p>
      </div>

      <!-- Display Cards — Interactive pillar showcase -->
      <div class="reveal flex items-center justify-center py-8" style="transition-delay: 200ms;">
        <DisplayCards client:only="react" />
      </div>
    </div>
  </div>
</section>
