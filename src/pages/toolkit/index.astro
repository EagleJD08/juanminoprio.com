---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import ToolkitCard from '@components/toolkit/ToolkitCard.astro';
import CuratedCard from '@components/toolkit/CuratedCard.astro';
import TabToggle from '@components/toolkit/TabToggle';
import ScrollReveal from '@components/ScrollReveal.astro';

const allTools = await getCollection('toolkit');
const builtTools = allTools.filter(t => t.data.type === 'built');
const curatedTools = allTools.filter(t => t.data.type === 'curated');
---

<BaseLayout
  title="Toolkit — Juan Minoprio"
  description="Open-source AI tools for marketers and builders. Built with Claude."
>
  <Navbar />

  <main id="main" class="pt-28 pb-24 md:pb-32">
    <div class="mx-auto max-w-6xl px-6">

      <!-- Header -->
      <div class="text-center mb-8 reveal">
        <span class="font-body text-xs uppercase tracking-widest text-terracotta">
          <span data-lang-en>Toolkit</span>
          <span data-lang-es>Toolkit</span>
        </span>
        <h1 class="mt-3 font-heading font-bold text-navy" style="font-size: clamp(1.75rem, 3vw + 0.5rem, 3rem);">
          <span data-lang-en>Tools I Built to Solve<br class="hidden sm:block" />My Own Problems</span>
          <span data-lang-es>Herramientas que Construí para<br class="hidden sm:block" />Resolver Mis Propios Problemas</span>
        </h1>
        <p class="mt-4 text-slate max-w-lg mx-auto text-base leading-relaxed">
          <span data-lang-en>Open-source AI tools for marketers and builders. Each one started as a personal itch — now they're yours to use.</span>
          <span data-lang-es>Herramientas de IA de código abierto para marketers y builders. Cada una empezó como una necesidad personal — ahora son tuyas.</span>
        </p>
      </div>

      <!-- Tab Toggle -->
      <div class="mb-10">
        <TabToggle client:load />
      </div>

      <!-- Built by Me Grid -->
      <div id="built-grid" class="flex flex-col gap-6">
        {builtTools.map((tool) => (
          <ToolkitCard
            title={tool.data.title}
            tagline={tool.data.tagline}
            tagline_es={tool.data.tagline_es}
            description={tool.data.description}
            description_es={tool.data.description_es}
            category={tool.data.category}
            githubUrl={tool.data.githubUrl}
            gradient={tool.data.gradient}
            icon={tool.data.icon}
            slug={tool.id.replace(/\.md$/, '')}
          />
        ))}
      </div>

      <!-- Curated Grid -->
      <div id="curated-grid" class="flex flex-col gap-6 hidden">
        {curatedTools.map((tool) => (
          <CuratedCard
            title={tool.data.title}
            tagline={tool.data.tagline}
            tagline_es={tool.data.tagline_es}
            description={tool.data.description}
            description_es={tool.data.description_es}
            category={tool.data.category}
            githubUrl={tool.data.githubUrl}
            gradient={tool.data.gradient}
            icon={tool.data.icon}
            creator={tool.data.creator}
          />
        ))}
        <!-- Coming soon placeholder -->
        <div class="border-2 border-dashed border-sand/40 rounded-2xl p-10 text-center">
          <p class="text-sm font-medium text-sand">
            <span data-lang-en>More curated tools coming soon</span>
            <span data-lang-es>Más herramientas seleccionadas próximamente</span>
          </p>
          <p class="text-xs text-sand/70 mt-1">
            <span data-lang-en>Tools I use and recommend for marketers and builders</span>
            <span data-lang-es>Herramientas que uso y recomiendo para marketers y builders</span>
          </p>
        </div>
      </div>

    </div>
  </main>

  <Footer />
  <ScrollReveal />
</BaseLayout>

<script>
  // Wire up tab toggle to show/hide grids
  const builtGrid = document.getElementById('built-grid');
  const curatedGrid = document.getElementById('curated-grid');

  window.addEventListener('toolkit-tab-change', ((e: CustomEvent) => {
    const tab = e.detail;
    if (tab === 'built') {
      builtGrid?.classList.remove('hidden');
      curatedGrid?.classList.add('hidden');
    } else {
      builtGrid?.classList.add('hidden');
      curatedGrid?.classList.remove('hidden');
    }
  }) as EventListener);
</script>
