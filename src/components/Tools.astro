      { name: "ChatGPT", description: "Investigación, brainstorming y borradores rápidos" },
      { name: "Cursor", description: "Editor de código con IA para dashboards y proyectos web" },
      { name: "Perplexity", description: "Investigación en tiempo real con fuentes citadas" },
      { name: "Gamma", description: "Presentaciones visuales asistidas por IA" },
    ],
  },
  {
    name: "Marketing & Analítica",
    color: "dusty-blue",
    tools: [
