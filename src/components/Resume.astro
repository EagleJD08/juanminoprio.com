---
import ResumeTimeline from './Timeline';
---

<section id="resume" class="py-24 md:py-32 bg-cream relative">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-sand to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal">
      <span class="font-body text-xs font-medium tracking-widest uppercase text-terracotta">Experience</span>
      <h2 class="mt-3 font-heading font-bold text-navy" style="font-size: clamp(1.75rem, 3vw + 0.5rem, 3rem);">Resume</h2>
      <p class="mt-4 text-slate max-w-xl text-sm md:text-base">
        A scroll-driven journey through my career — from current work to certifications and skills.
      </p>
    </div>

    <div class="mt-8">
      <ResumeTimeline client:only="react" />
    </div>
  </div>
</section>
