---
const socialLinks = [
  { label: "LinkedIn", href: "https://www.linkedin.com/in/juanminoprio/", icon: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" },
];
const currentYear = new Date().getFullYear();
---

<footer class="py-10 bg-ink border-t border-snow/[0.06]">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <span class="font-heading font-bold text-lg text-white">JM</span>
        <span class="text-snow/20">|</span>
        <span class="text-xs text-snow/30 font-body">Juan Minoprio</span>
      </div>

      <div class="flex items-center gap-2">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={link.label}
            class="w-9 h-9 rounded-xl bg-snow/[0.05] flex items-center justify-center cursor-pointer hover:bg-snow/[0.1] hover:-translate-y-0.5 transition-all duration-300"
          >
            <svg class="w-4 h-4 fill-snow/50 hover:fill-snow/80 transition-colors duration-300" viewBox="0 0 24 24"><path d={link.icon} /></svg>
          </a>
        ))}
      </div>
    </div>

    <div class="mt-6 pt-6 border-t border-snow/[0.06] text-center">
      <p class="text-xs text-snow/25">
        &copy; {currentYear} Juan Minoprio. All rights reserved.
      </p>
    </div>
  </div>
</footer>
