    ],
  },
  {
    name: "Diseño",
    color: "soft-plum",
    tools: [
      { name: "Figma", description: "Wireframes, sistemas visuales y diseño de campañas" },
      { name: "Canva", description: "Gráficos sociales rápidos y presentaciones para stakeholders" },
      { name: "Adobe Express", description: "Plantillas de marca para producción de contenido rápido" },
      { name: "Recharts", description: "Visualizaciones de datos en React para storytelling interactivo" },
    ],
  },
  {
    name: "Datos & Desarrollo",
    color: "sage",
    tools: [
      { name: "Astro + React", description: "Framework de este sitio y proyectos de portfolio interactivos" },
      { name: "Python + Pandas", description: "Procesamiento de datos y análisis exploratorio" },
      { name: "Tailwind CSS", description: "Estilos utilitarios para UI rápida y consistente" },
      { name: "Cloudflare Pages", description: "Despliegue edge con tiempos de carga globales bajo 100ms" },
    ],
  },
  {
    name: "Productividad",
    color: "sand",
    tools: [
      { name: "Notion", description: "Segundo cerebro — notas Zettelkasten, proyectos y calendario de contenido" },
      { name: "Obsidian", description: "Pensamiento profundo y notas enlazadas" },
      { name: "GitHub", description: "Control de versiones para proyectos de marketing tech y datos" },
      { name: "Slack", description: "Colaboración interfuncional y flujos de trabajo asíncronos" },
    ],
  },
];

const dotColorMap: Record<string, string> = {
  terracotta: "bg-terracotta",
  "dusty-blue": "bg-dusty-blue",
  sage: "bg-sage",
  "soft-plum": "bg-soft-plum",
  sand: "bg-sand",
};

const labelColorMap: Record<string, string> = {
  terracotta: "text-terracotta",
  "dusty-blue": "text-dusty-blue",
  sage: "text-sage",
  "soft-plum": "text-soft-plum",
  sand: "text-slate",
};
---

<section id="tools" class="py-24 md:py-32 bg-cream relative">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-sand to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal max-w-2xl">
      <span class="font-body text-xs font-medium tracking-widest uppercase text-terracotta">
        <span data-lang-en>My toolkit</span>
        <span data-lang-es>Mis herramientas</span>
      </span>
      <h2 class="mt-3 font-heading font-bold text-navy" style="font-size: clamp(1.75rem, 3vw + 0.5rem, 3rem);">
        <span data-lang-en>Tools I use</span>
        <span data-lang-es>Herramientas que uso</span>
      </h2>
      <p class="mt-4 text-slate">
        <span data-lang-en>A curated set of tools that power my workflows across marketing, analytics, AI, and data storytelling.</span>
        <span data-lang-es>Un conjunto curado de herramientas que potencian mis flujos en marketing, analítica, IA y storytelling de datos.</span>
      </p>
    </div>

    <!-- English tools -->
    <div data-lang-en class="mt-16 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-12 md:gap-x-16 md:gap-y-14">
      {categoriesEn.map((cat) => (
        <div class="reveal">
          <div class="flex items-center gap-2.5 mb-5">
            <div class={`w-2 h-2 rounded-full ${dotColorMap[cat.color] || "bg-sand"}`}></div>
            <span class={`text-xs font-medium tracking-widest uppercase ${labelColorMap[cat.color] || "text-slate"}`}>{cat.name}</span>
          </div>
          <div class="space-y-0">
            {cat.tools.map((tool) => (
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5 sm:gap-4 py-3 border-b border-sand/30 last:border-0">
                <h3 class="font-heading font-semibold text-navy whitespace-nowrap">{tool.name}</h3>
                <p class="text-sm text-slate sm:text-right leading-snug">{tool.description}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Spanish tools -->
    <div data-lang-es class="mt-16 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-12 md:gap-x-16 md:gap-y-14">
      {categoriesEs.map((cat) => (
        <div class="reveal">
          <div class="flex items-center gap-2.5 mb-5">
            <div class={`w-2 h-2 rounded-full ${dotColorMap[cat.color] || "bg-sand"}`}></div>
            <span class={`text-xs font-medium tracking-widest uppercase ${labelColorMap[cat.color] || "text-slate"}`}>{cat.name}</span>
          </div>
          <div class="space-y-0">
            {cat.tools.map((tool) => (
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5 sm:gap-4 py-3 border-b border-sand/30 last:border-0">
                <h3 class="font-heading font-semibold text-navy whitespace-nowrap">{tool.name}</h3>
                <p class="text-sm text-slate sm:text-right leading-snug">{tool.description}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
