---
const tools = [
  { name: "Google Analytics", category: "Marketing", description: "Data and performance tracking", color: "cocoa" },
  { name: "Adobe Creative Suite", category: "Design", description: "Illustrator, Photoshop, and InDesign", color: "navy" },
  { name: "Claude", category: "AI", description: "Writing, analysis, and building systems", color: "charcoal" },
  { name: "ChatGPT", category: "AI", description: "Research and brainstorming", color: "charcoal" },
  { name: "Notion", category: "Productivity", description: "Knowledge management and planning", color: "navy" },
  { name: "GitHub", category: "Productivity", description: "Code hosting and version control", color: "navy" },
];

const colorMap: Record<string, string> = {
  cocoa: "group-hover:border-cocoa/30 group-hover:shadow-cocoa/[0.05]",
  navy: "group-hover:border-navy/30 group-hover:shadow-navy/[0.05]",
  charcoal: "group-hover:border-charcoal/30 group-hover:shadow-charcoal/[0.05]",
};
const dotMap: Record<string, string> = {
  cocoa: "bg-cocoa",
  navy: "bg-navy",
  charcoal: "bg-charcoal",
};
---

<section id="tools" class="py-24 md:py-32 bg-snow relative">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-mushroom to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal text-center max-w-2xl mx-auto">
      <span class="font-body text-xs font-medium tracking-widest uppercase text-cocoa">Stack</span>
      <h2 class="mt-3 font-heading font-bold text-3xl md:text-5xl text-ink">Tools I use.</h2>
      <p class="mt-4 text-charcoal">
        A curated set of tools that power my workflows across marketing, analysis, and AI productivity.
      </p>
    </div>

    <div class="mt-16 stagger-children grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map((tool) => (
        <div class={`reveal group p-5 rounded-2xl border border-mushroom/50 bg-white/60 cursor-default hover:bg-white hover:shadow-lg hover:-translate-y-0.5 ${colorMap[tool.color] || ""} transition-all duration-300`}>
          <div class="flex items-center gap-3">
            <div class={`w-2 h-2 rounded-full ${dotMap[tool.color] || "bg-mushroom"}`}></div>
            <span class="text-[10px] font-medium tracking-widest uppercase text-charcoal/50">{tool.category}</span>
          </div>
          <h3 class="mt-3 font-heading font-semibold text-ink">{tool.name}</h3>
          <p class="mt-1 text-sm text-charcoal">{tool.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
