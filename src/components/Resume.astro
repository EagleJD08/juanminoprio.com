---
import ResumeTimeline from './Timeline';
---

<section id="resume" class="py-24 md:py-32 bg-snow relative">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-mushroom to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal">
      <span class="font-body text-xs font-medium tracking-widest uppercase text-cocoa">Experience</span>
      <h2 class="mt-3 font-heading font-bold text-3xl md:text-5xl text-ink">Resume.</h2>
      <p class="mt-4 text-charcoal max-w-xl text-sm md:text-base">
        A scroll-driven journey through my career — from current work to certifications and skills.
      </p>
    </div>

    <div class="mt-8">
      <ResumeTimeline client:only="react" />
    </div>
  </div>
</section>
