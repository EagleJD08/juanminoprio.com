---
import { getCollection } from 'astro:content';

const portfolioEntries = await getCollection('portfolio');
const hasEntries = portfolioEntries.length > 0;

const pillarStyles: Record<string, { bg: string; text: string; border: string }> = {
  business: { bg: 'bg-dusty-blue/10', text: 'text-dusty-blue', border: 'group-hover:border-dusty-blue/30' },
  marketing: { bg: 'bg-terracotta/10', text: 'text-terracotta', border: 'group-hover:border-terracotta/30' },
  ai: { bg: 'bg-sage/10', text: 'text-sage', border: 'group-hover:border-sage/30' },
};
---

<section id="portfolio" class="py-24 md:py-32 bg-cream relative">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-sand to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <span class="font-body text-xs font-medium tracking-widest uppercase text-terracotta">Portfolio</span>
        <h2 class="mt-3 font-heading font-bold text-3xl md:text-5xl text-navy">
          Selected work.
        </h2>
      </div>
      <p class="text-slate max-w-md text-sm md:text-base md:text-right">
        Case studies and data-driven analysis — each piece demonstrates how I think about business, marketing, and technology.
      </p>
    </div>

    {hasEntries ? (
      <div class="mt-16 stagger-children grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {portfolioEntries.map((entry) => {
          const style = pillarStyles[entry.data.pillar] || { bg: 'bg-sand/30', text: 'text-slate', border: '' };
          return (
            <a
              href={`/portfolio/${entry.id}`}
              class={`reveal group block rounded-2xl border border-sand/50 bg-white overflow-hidden cursor-pointer hover:shadow-xl hover:shadow-navy/[0.06] hover:-translate-y-1 ${style.border} transition-all duration-300`}
            >
              <div class="aspect-[16/10] bg-gradient-to-br from-sand/30 to-sand/60 flex items-center justify-center relative overflow-hidden">
                <div class="absolute inset-0 bg-navy/0 group-hover:bg-navy/[0.03] transition-colors duration-300"></div>
                <span class="text-sm text-slate/30 font-body">Thumbnail</span>
              </div>
              <div class="p-6">
                <span class={`inline-block px-3 py-1 rounded-full text-[11px] font-medium tracking-wide uppercase ${style.bg} ${style.text}`}>
                  {entry.data.pillar}
                </span>
                <h3 class="mt-3 font-heading font-semibold text-lg text-navy group-hover:text-terracotta transition-colors duration-300 leading-snug">
                  {entry.data.title}
                </h3>
                <p class="mt-2 text-sm text-slate line-clamp-2 leading-relaxed">
                  {entry.data.description}
                </p>
                <div class="mt-4 flex items-center gap-2 text-xs font-medium text-terracotta opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  Read case study
                  <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="reveal mt-16 rounded-2xl border-2 border-dashed border-sand/60 bg-white/50 p-16 text-center">
        <div class="w-16 h-16 mx-auto rounded-2xl bg-sand/30 flex items-center justify-center">
          <svg class="w-7 h-7 text-slate/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
        </div>
        <p class="mt-5 font-heading font-semibold text-lg text-navy">Coming Soon</p>
        <p class="mt-2 text-sm text-slate max-w-sm mx-auto">
          Case studies and project breakdowns are on the way. Follow along on LinkedIn for updates.
        </p>
      </div>
    )}
  </div>
</section>
